@startuml seq_wishlist
title Hình 3.26 — Sequence Diagram — Quản lý Wishlist

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

== Thêm vào Wishlist ==
Customer -> FE : Nhấn icon ♡ trên sản phẩm
FE -> BE : POST /api/v1/wishlist/{productId}
BE -> BE : Validate JWT → accountId
BE -> DB : INSERT Wishlist\n(account_id, product_id)
BE --> FE : 200 {message:\n"Đã thêm vào danh sách yêu thích"}
FE --> Customer : Icon ♥ chuyển sang đỏ

== Xóa khỏi Wishlist ==
Customer -> FE : Nhấn icon ♥ (bỏ thích)
FE -> BE : DELETE /api/v1/wishlist/{productId}
BE -> BE : Validate JWT → accountId
BE -> DB : DELETE Wishlist\nWHERE account_id = ?\nAND product_id = ?
BE --> FE : 200 {message:\n"Đã xóa khỏi danh sách yêu thích"}
FE --> Customer : Icon ♡ chuyển về trắng

== Xem danh sách Wishlist ==
Customer -> FE : Mở trang Wishlist
FE -> BE : GET /api/v1/wishlist
BE -> BE : Validate JWT → accountId
BE -> DB : SELECT Wishlist JOIN Product\nWHERE account_id = ?
BE --> FE : 200 {wishlistItems[]}
FE --> Customer : Hiển thị danh sách SP yêu thích

@enduml
