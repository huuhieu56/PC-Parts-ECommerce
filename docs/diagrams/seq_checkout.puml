@startuml seq_checkout
title Hình 3.19 — Sequence Diagram — Checkout & Tạo đơn hàng

actor Customer
participant "Next.js" as FE
participant "Spring Boot" as BE
database "PostgreSQL" as DB
participant "MoMo Gateway" as Pay

Customer -> FE : Nhấn "Đặt hàng"
FE -> BE : POST /api/v1/orders\n{addressId, paymentMethod,\ncouponCode?, note?}
BE -> BE : Validate JWT → accountId

BE -> DB : SELECT Address\nWHERE id = ? AND account_id = ?
alt Không tìm thấy Address
    BE --> FE : 400/404\n{Vui lòng chọn địa chỉ giao hàng}
end

opt Có couponCode
    BE -> DB : SELECT Coupon WHERE code = ?
    BE -> BE : Validate (còn hạn,\nchưa max_uses,\nmin_order_value)
end

BE -> DB : SELECT Cart + Cart_Item\nWHERE account_id = ?
loop Mỗi Cart_Item
    BE -> DB : SELECT Inventory\nWHERE product_id = ?
    BE -> BE : Kiểm tra quantity >= requested
end

alt Giỏ hàng trống hoặc hết hàng
    BE --> FE : 400/409\n{message lỗi}
else Đủ hàng
    BE -> DB : INSERT Orders (status=PENDING)
    BE -> DB : INSERT Order_Detail[]\n(snapshot đơn giá)
    BE -> DB : INSERT Payment\n(status=PENDING,\nmethod=COD/MOMO)
    BE -> DB : INSERT Shipping
    BE -> DB : INSERT Order_Status_History\n(PENDING)

    loop Trừ kho
        BE -> DB : UPDATE Inventory\nSET quantity -= ?
        BE -> DB : INSERT Inventory_Log\n(type=SELL)
    end

    opt Có Coupon
        BE -> DB : INSERT Coupon_Usage
        BE -> DB : UPDATE Coupon\nSET used_count += 1
    end

    BE -> DB : DELETE Cart_Item\n(các item đã đặt)

    alt Thanh toán Online (MoMo)
        BE -> Pay : Tạo payment URL
        Pay --> BE : Payment URL
        BE --> FE : 200 {orderId, paymentUrl}
        FE --> Customer : Redirect sang cổng thanh toán
    else COD
        BE --> FE : 201 {order}
        FE --> Customer : Hiển thị\n"Đặt hàng thành công"
    end
end

@enduml
