@startuml seq_change_password
title Hình 3.13 — Sequence Diagram — Thay đổi mật khẩu

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

Customer -> FE : Nhập mật khẩu cũ + mật khẩu mới
FE -> FE : Validate (mật khẩu mới ≥ 8 ký tự,\ncó chữ hoa, số, ký tự đặc biệt)
FE -> BE : PUT /api/v1/users/password\n{currentPassword, newPassword}
BE -> BE : Validate JWT → lấy email (auth.getName())
BE -> DB : SELECT Account WHERE email = ?
DB --> BE : Account (password_hash)
BE -> BE : Verify BCrypt(currentPassword, hash)

alt Mật khẩu cũ sai
    BE --> FE : 400 {message: "Mật khẩu hiện tại không đúng"}
    FE --> Customer : Hiển thị lỗi
else Đúng
    BE -> BE : BCrypt hash newPassword
    BE -> DB : UPDATE Account SET password_hash = ?
    BE --> FE : 200 {message: "Đổi mật khẩu thành công"}
    FE --> Customer : Thông báo thành công
end

@enduml
