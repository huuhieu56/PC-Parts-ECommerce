@startuml seq_change_password
title Hình 3.13 — Sequence Diagram — Thay đổi mật khẩu

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

Customer -> FE : Nhập mật khẩu cũ + mật khẩu mới\n+ xác nhận mật khẩu
FE -> FE : Validate (mật khẩu mới ≥ 8 ký tự,\nbao gồm chữ hoa, chữ thường và số)
FE -> BE : PUT /api/v1/users/password\n{currentPassword, newPassword,\nconfirmPassword}
BE -> BE : Validate JWT → auth.getName()\n→ accountId
BE -> DB : SELECT Account WHERE id = ?
DB --> BE : Account (password_hash)
BE -> BE : Verify BCrypt(currentPassword, hash)

alt Mật khẩu cũ sai
    BE --> FE : 400 {message:\n"Mật khẩu hiện tại không chính xác"}
else confirmPassword không khớp newPassword
    BE --> FE : 400 {message:\n"Mật khẩu xác nhận không khớp"}
else newPassword trùng currentPassword
    BE --> FE : 400 {message:\n"Mật khẩu mới phải khác mật khẩu cũ"}
else newPassword không đủ mạnh
    BE --> FE : 400 {message: validation error}
else Hợp lệ
    BE -> BE : BCrypt hash newPassword
    BE -> DB : UPDATE Account SET password_hash = ?
    BE -> DB : DELETE Token\nWHERE account_id = ?\nAND token_type = 'REFRESH'\n(buộc đăng nhập lại)
    BE --> FE : 200 {message:\n"Đổi mật khẩu thành công"}
    FE --> Customer : Thông báo thành công
end

@enduml
