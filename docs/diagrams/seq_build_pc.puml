@startuml seq_build_pc
title Hình 3.27 — Sequence Diagram — Build PC + Kiểm tra tương thích AI

actor User
participant "Next.js" as FE
participant "Spring Boot" as BE
participant "LLM API" as LLM

User -> FE : Mở trang Build PC
FE -> FE : Hiển thị giao diện chọn linh kiện\n(dùng dữ liệu từ API products\nvà categories đã có)

loop Chọn linh kiện cho mỗi slot
    User -> FE : Chọn sản phẩm cho slot\n(CPU, Main, RAM, ...)
    FE -> FE : Cập nhật cấu hình,\ntính tổng giá
end

User -> FE : Nhấn "Kiểm tra tương thích"
FE -> BE : POST /api/v1/build-pc/check-compatibility\n{components[{productId, name,\ncategory, specs}]}
BE -> BE : @PreAuthorize(isAuthenticated)
BE -> BE : Build prompt với thông số\nkỹ thuật các linh kiện
BE -> LLM : Gửi prompt kiểm tra tương thích
LLM --> BE : Kết quả phân tích
BE --> FE : 200 {compatible: true/false,\nanalysis, suggestions[]}
FE --> User : Hiển thị kết quả AI\n(tương thích/không, phân tích chi tiết)

@enduml
