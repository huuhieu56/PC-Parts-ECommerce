@startuml seq_logout_refresh
title Hình 3.12 — Sequence Diagram — Đăng xuất & Refresh Token

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

== Luồng Refresh Token (Rotation) ==
FE -> FE : Access Token hết hạn
FE -> BE : POST /api/v1/auth/refresh-token\n{refreshToken}
BE -> BE : Validate JWT signature + expiry
BE -> DB : SELECT Token\nWHERE token_value = ?\nAND token_type = 'REFRESH'

alt Refresh Token hợp lệ + chưa hết hạn
    BE -> DB : DELETE Token\nWHERE account_id = ?\nAND token_type IN ('ACCESS','REFRESH')
    BE -> BE : Sinh Access Token mới\n+ Refresh Token mới (rotation)
    BE -> DB : INSERT Token (ACCESS)\n+ INSERT Token (REFRESH)
    BE --> FE : 200 {accessToken,\nrefreshToken, user}
    FE -> FE : Cập nhật cả 2 token\ntrong localStorage
else Refresh Token hết hạn / không hợp lệ
    BE --> FE : 401 Unauthorized
    FE -> FE : Xóa token,\nredirect /login?expired=true
end

== Luồng Đăng xuất ==
Customer -> FE : Nhấn "Đăng xuất"
FE -> BE : POST /api/v1/auth/logout\n(Bearer Token trong header)
BE -> BE : Validate JWT → auth.getName()\n→ accountId
BE -> DB : DELETE Token\nWHERE account_id = ?\n(xóa tất cả token)
BE --> FE : 200 {message:\n"Đăng xuất thành công"}
FE -> FE : Xóa localStorage\n(accessToken, refreshToken,\nauth-storage, cart-storage)
FE --> Customer : Redirect về trang chủ

@enduml
