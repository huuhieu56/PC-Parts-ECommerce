@startuml seq_cart
title Hình 3.18 — Sequence Diagram — Quản lý giỏ hàng (Guest & Customer)

actor User
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "Redis" as Cache
database "PostgreSQL" as DB

== Thêm sản phẩm vào giỏ ==
User -> FE : Nhấn "Thêm vào giỏ"\n(product_id, quantity)

alt Chưa đăng nhập (Guest)
    FE -> BE : POST /api/v1/cart/items\nHeader: X-Session-Id: {uuid}\n{productId, quantity}
    BE -> Cache : Lưu cart item vào Redis\n(key: session_id)
    BE --> FE : 200 {cart}
else Đã đăng nhập (Customer)
    FE -> BE : POST /api/v1/cart/items\nHeader: Authorization: Bearer {token}\n{productId, quantity}
    BE -> BE : Validate JWT → accountId
    BE -> DB : SELECT/INSERT Cart\nWHERE account_id = ?
    BE -> DB : UPSERT Cart_Item\n(cart_id, product_id, quantity)
    BE --> FE : 200 {cart}
end

FE --> User : Cập nhật icon giỏ hàng

== Xem giỏ hàng ==
User -> FE : Mở trang giỏ hàng
FE -> BE : GET /api/v1/cart\nHeader: X-Session-Id / Authorization
BE --> FE : 200 {items[], totalPrice}
FE --> User : Hiển thị giỏ hàng

== Cập nhật số lượng ==
User -> FE : Thay đổi số lượng
FE -> BE : PUT /api/v1/cart/items/{productId}\n?quantity=3\nHeader: X-Session-Id / Authorization
BE --> FE : 200 {updatedCart}

== Xóa sản phẩm ==
User -> FE : Nhấn "Xóa"
FE -> BE : DELETE /api/v1/cart/items/{productId}\nHeader: X-Session-Id / Authorization
BE --> FE : 200 {updatedCart}

== Xóa toàn bộ giỏ ==
User -> FE : Nhấn "Xóa giỏ hàng"
FE -> BE : DELETE /api/v1/cart\nHeader: X-Session-Id / Authorization
BE --> FE : 200 {message: "Đã xóa giỏ hàng"}

@enduml
