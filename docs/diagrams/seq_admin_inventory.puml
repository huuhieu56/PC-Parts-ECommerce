@startuml seq_admin_inventory
title Hình 3.30 — Sequence Diagram — Admin quản lý tồn kho

actor "Warehouse Staff" as Warehouse
participant "Next.js\n(Admin CMS)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

== Xem tồn kho sản phẩm ==
Warehouse -> FE : Mở trang tồn kho\ncủa sản phẩm
FE -> BE : GET /api/v1/inventory/{productId}
BE -> BE : Validate JWT + Authority\n(inventory.view)
BE -> DB : SELECT Inventory\nWHERE product_id = ?
BE --> FE : 200 {productId, quantity,\nlowStockThreshold}
FE --> Warehouse : Hiển thị thông tin tồn kho

== Nhập hàng ==
Warehouse -> FE : Nhập số lượng + lý do
FE -> BE : POST /api/v1/inventory/{productId}/import\n{quantity, reason}
BE -> BE : Validate JWT + Authority\n(inventory.import)
BE -> DB : UPDATE Inventory\nSET quantity += ?
BE -> DB : INSERT Inventory_Log\n(product_id, type='IMPORT',\nquantity_change=+?,\nperformed_by=accountId, reason)
BE --> FE : 200 {updatedInventory}
FE --> Warehouse : Cập nhật số lượng tồn kho

== Xuất hàng ==
Warehouse -> FE : Xuất số lượng + lý do
FE -> BE : POST /api/v1/inventory/{productId}/export\n{quantity, reason}
BE -> BE : Validate JWT + Authority\n(inventory.import)
BE -> DB : UPDATE Inventory\nSET quantity -= ?
BE -> DB : INSERT Inventory_Log\n(type='EXPORT')
BE --> FE : 200 {updatedInventory}

== Kiểm kê / Điều chỉnh kho ==
Warehouse -> FE : Nhập số lượng điều chỉnh\n+ lý do
FE -> BE : POST /api/v1/inventory/{productId}/adjust\n{quantity, reason}
BE -> BE : Validate JWT + Authority\n(inventory.adjust)
BE -> DB : UPDATE Inventory\nSET quantity = ?
BE -> DB : INSERT Inventory_Log\n(type='ADJUSTMENT',\nquantity_change=diff)
BE --> FE : 200 {updatedInventory}

== Xem lịch sử biến động ==
FE -> BE : GET /api/v1/inventory/{productId}/logs\n?page=0&size=20
BE -> BE : Validate JWT + Authority\n(inventory.view)
BE -> DB : SELECT Inventory_Log\nWHERE product_id = ?\nORDER BY created_at DESC
BE --> FE : 200 {logs[] (paginated)}

@enduml
