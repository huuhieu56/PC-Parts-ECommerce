@startuml seq_forgot_password
title Hình 3.14 — Sequence Diagram — Quên & Thiết lập lại mật khẩu

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB
participant "Email Service\n(SMTP)" as Email

Customer -> FE : Nhập email, nhấn "Quên mật khẩu"
FE -> BE : POST /api/v1/auth/forgot-password\n{email}
BE -> DB : SELECT Account WHERE email = ?

alt Email không tồn tại hoặc tài khoản bị khóa
    BE --> FE : 200 {message: "Nếu email tồn tại,\nlink reset đã được gửi"}
    note over BE : Trả 200 để tránh lộ email tồn tại
else Email tồn tại + tài khoản active
    BE -> DB : DELETE Token\nWHERE account_id = ?\nAND token_type = 'RESET_PASSWORD'
    BE -> BE : Sinh reset token\n(UUID + expiry 30 phút)
    BE -> DB : INSERT Token\n(type=RESET_PASSWORD, token_value, expires_at)
    BE -> Email : Gửi email chứa link reset password
    Email --> Customer : Email với link\n/reset-password?token=xxx
    BE --> FE : 200 {message: "Nếu email tồn tại,\nlink reset đã được gửi"}
end

FE --> Customer : Hiển thị thông báo kiểm tra email

== Thiết lập lại mật khẩu ==
Customer -> FE : Mở link reset, nhập mật khẩu mới\n+ xác nhận mật khẩu
FE -> BE : POST /api/v1/auth/reset-password\n{token, newPassword, confirmPassword}
BE -> DB : SELECT Token WHERE token_value = ?\nAND type = 'RESET_PASSWORD'

alt Token hết hạn / không hợp lệ
    BE --> FE : 400 {message:\n"Liên kết đã hết hạn.\nVui lòng yêu cầu lại"}
else confirmPassword không khớp
    BE --> FE : 400 {message: validation error}
else Token hợp lệ
    BE -> BE : BCrypt hash newPassword
    BE -> DB : UPDATE Account SET password_hash = ?
    BE -> DB : DELETE Token WHERE account_id = ?\n(xóa tất cả token cũ)
    BE --> FE : 200 {message:\n"Đặt lại mật khẩu thành công"}
    FE --> Customer : Redirect đến trang đăng nhập
end

@enduml
