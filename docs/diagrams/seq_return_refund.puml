@startuml seq_return_refund
title Hình 3.23 — Sequence Diagram — Đổi trả & Hoàn tiền

actor Customer
actor "Admin/Sales" as Staff
participant "Next.js" as FE
participant "Spring Boot" as BE
database "PostgreSQL" as DB

== Customer tạo yêu cầu đổi trả ==
Customer -> FE : Tạo yêu cầu đổi trả
FE -> BE : POST /api/v1/returns\n{orderId, orderDetailId,\ntype, reason}
BE -> BE : Validate JWT → accountId
BE -> DB : SELECT Order + Order_Detail
BE -> BE : Validate owner,\norder status, return policy
alt Không hợp lệ
    BE --> FE : 400/403/409 {message}
else Hợp lệ
    BE -> DB : INSERT Return_Request\n(status=PENDING)
    BE --> FE : 201 {return}
end

== Customer xem yêu cầu ==
Customer -> FE : Mở trang đổi trả
FE -> BE : GET /api/v1/returns/my\n?page=0&size=10
BE -> BE : Validate JWT → accountId
BE -> DB : SELECT Return_Request\nWHERE account_id = ?
BE --> FE : 200 {returns[] (paginated)}

== Admin xem tất cả yêu cầu ==
Staff -> FE : Mở trang quản lý đổi trả
FE -> BE : GET /api/v1/returns\n?status=PENDING&page=0&size=10
BE -> BE : Validate JWT + Authority\n(return.view / return.manage)
BE --> FE : 200 {returns[] (paginated)}

== Admin cập nhật trạng thái ==
Staff -> FE : Duyệt / Từ chối yêu cầu
FE -> BE : PUT /api/v1/returns/{id}/status\n?status=APPROVED&refundAmount=500000
BE -> BE : Validate JWT + Authority\n(return.manage)
BE -> DB : UPDATE Return_Request\nSET status = ?, refund_amount = ?
BE --> FE : 200 {updatedReturn}

@enduml
