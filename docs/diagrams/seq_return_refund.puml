@startuml seq_return_refund
title Hình 3.23 — Sequence Diagram — Đổi trả & Hoàn tiền

actor Customer
actor "Admin/Sales" as Staff
participant "Next.js" as FE
participant "Spring Boot" as BE
database "PostgreSQL" as DB
collections "MinIO" as MinIO

Customer -> FE : Tạo yêu cầu đổi trả
FE -> BE : POST /api/v1/returns\n{order_id, order_detail_id,\ntype, reason, images[]}
BE -> BE : Validate JWT (Customer)
BE -> DB : SELECT Order + Order_Detail
BE -> DB : SELECT Return_Policy\n(Product > Category)
BE -> BE : Validate owner, COMPLETED,\nreturn window, not excluded,\nno duplicate pending request

alt Không hợp lệ
    BE --> FE : 400/403/409 {message}
else Hợp lệ
    opt Có ảnh minh chứng
        BE -> MinIO : Upload images
    end
    BE -> DB : INSERT Return\n(status=PENDING_APPROVAL)
    opt Có ảnh minh chứng
        BE -> DB : INSERT Return_Image\n(image_url)
    end
    BE --> FE : 201 {returnId, status}
end

note over BE, DB : Admin/Sales duyệt
Staff -> FE : Mở chi tiết yêu cầu đổi trả
FE -> BE : PATCH /api/v1/admin/returns/{id}

alt Duyệt - REFUND
    BE -> DB : UPDATE Return\nSET status=APPROVED,\nresolved_by=staff_id
    BE -> DB : INSERT Payment\n(status=REFUNDED, amount=refund_amount)
    BE -> DB : UPDATE Inventory\nSET quantity += ?
    BE -> DB : INSERT Inventory_Log\n(type=RETURN)
    BE -> DB : UPDATE Return\nSET status=COMPLETED,\nresolved_at=NOW()
else Duyệt - EXCHANGE
    BE -> DB : UPDATE Return\nSET status=APPROVED,\nresolved_by=staff_id
    BE -> DB : UPDATE Inventory\n(hoàn kho SP cũ)
    BE -> DB : INSERT Order mới\n(SP thay thế)
    BE -> DB : UPDATE Return\nSET status=COMPLETED,\nreplacement_order_id=order_id,\nresolved_at=NOW()
else Từ chối
    BE -> DB : UPDATE Return\nSET status=REJECTED,\nrejection_reason="Lý do",\nresolved_at=NOW()
end

@enduml
