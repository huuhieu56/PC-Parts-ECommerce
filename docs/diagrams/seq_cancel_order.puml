@startuml seq_cancel_order
title Hình 3.16 — Sequence Diagram — Hủy đơn hàng

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

Customer -> FE : Nhấn "Hủy đơn hàng"
FE -> BE : PATCH /api/v1/orders/{id}/cancel\n{reason?}
BE -> BE : Validate JWT → user_id

BE -> DB : SELECT Orders\nWHERE id = ? AND user_id = ?
DB --> BE : Order (status, coupon_id)

alt Đơn không phải PENDING
    BE --> FE : 400 {message: "Chỉ hủy được\nđơn hàng đang chờ xử lý"}
else Đơn hàng PENDING
    BE -> DB : UPDATE Orders\nSET status = 'CANCELLED'
    BE -> DB : INSERT Order_Status_History\n(PENDING → CANCELLED, note=reason)

    loop Hoàn kho — mỗi Order_Detail
        BE -> DB : SELECT Order_Detail\nWHERE order_id = ?
        BE -> DB : UPDATE Inventory\nSET quantity += order_detail.quantity
        BE -> DB : INSERT Inventory_Log\n(type='CANCEL', +quantity,\nnote='Hủy đơn #id')
    end

    opt Có Coupon
        BE -> DB : UPDATE Coupon\nSET used_count -= 1
        BE -> DB : DELETE Coupon_Usage\nWHERE order_id = ?
    end

    opt Đã thanh toán Online
        BE -> DB : UPDATE Payment\nSET status = 'REFUNDED'
        note over BE : Trigger hoàn tiền\nqua VNPay/MoMo API
    end

    BE -> DB : INSERT Notification\n(user_id, "Đơn hàng #id đã được hủy")
    BE --> FE : 200 {message: "Hủy đơn hàng thành công"}
    FE --> Customer : Cập nhật trạng thái đơn
end

@enduml
