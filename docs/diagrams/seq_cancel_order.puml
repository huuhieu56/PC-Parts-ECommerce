@startuml seq_cancel_order
title Hình 3.22 — Sequence Diagram — Hủy đơn hàng

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

Customer -> FE : Nhấn "Hủy đơn hàng"
FE -> BE : PUT /api/v1/orders/{id}/cancel
BE -> BE : Validate JWT → accountId

BE -> DB : SELECT UserProfile\nWHERE account_id = ?
BE -> DB : SELECT Orders WHERE id = ?
DB --> BE : Order (status, user_id,\ncoupon_id, payment)

BE -> BE : Kiểm tra quyền sở hữu:\norder.user_id == userProfile.id

alt Không phải đơn của mình
    BE --> FE : 403 {message:\n"Bạn không có quyền hủy đơn hàng này"}
else Trạng thái != PENDING
    BE --> FE : 400 {message:\n"Chỉ có thể hủy đơn hàng\nđang chờ xử lý"}
else PENDING → CANCELLED ✓
    BE -> DB : UPDATE Orders\nSET status = 'CANCELLED'

    loop Hoàn kho — mỗi Order_Detail
        BE -> DB : UPDATE Inventory\nSET quantity += order_detail.quantity
    end

    opt Có Coupon
        BE -> DB : UPDATE Coupon\nSET used_count -= 1
    end

    opt Có Payment
        BE -> DB : UPDATE Payment\nSET status = 'CANCELLED'
    end

    BE -> DB : INSERT Order_Status_History\n(PENDING → CANCELLED,\nnote="Khách hàng hủy đơn")
    BE --> FE : 200 {updatedOrder}
    FE --> Customer : Cập nhật trạng thái đơn
end

@enduml
