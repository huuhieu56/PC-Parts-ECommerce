@startuml uc_CUS13_lich_su_don_hang
left to right direction
skinparam actorStyle awesome
skinparam packageStyle rectangle
skinparam usecase {
  BackgroundColor #FEFECE
  BorderColor #A80036
  ArrowColor #A80036
}

title UC-CUS-13: Xem lịch sử đơn hàng và theo dõi vận chuyển

actor "Khách hàng\n(Customer)" as Customer

rectangle "Hệ thống PC Parts E-Commerce" {
  usecase "Xem lịch sử đơn hàng\nvà theo dõi vận chuyển" as UC_HISTORY
  usecase "Hiển thị danh sách Order\n(mã, ngày, tổng tiền,\ntrạng thái)" as UC_LIST
  usecase "Lọc theo trạng thái\nvà khoảng thời gian" as UC_FILTER
  usecase "Xem chi tiết Order\n(Order_Detail, Address,\nPayment)" as UC_DETAIL
  usecase "Xem Shipping\n(đơn vị, tracking,\ntrạng thái, ngày giao)" as UC_SHIPPING
  usecase "Xem Order_Status_History\n(lịch sử trạng thái)" as UC_STATUS_HIST
  usecase "Không có đơn hàng\n→ Hiển thị thông báo" as UC_ERR_EMPTY
}

Customer --> UC_HISTORY

UC_HISTORY ..> UC_LIST : <<include>>
UC_HISTORY ..> UC_FILTER : <<include>>
UC_HISTORY ..> UC_DETAIL : <<include>>
UC_HISTORY ..> UC_SHIPPING : <<include>>
UC_HISTORY ..> UC_STATUS_HIST : <<include>>
UC_LIST ..> UC_ERR_EMPTY : <<extend>>

@enduml
