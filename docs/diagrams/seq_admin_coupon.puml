@startuml seq_admin_coupon
title Hình 3.33 — Sequence Diagram — Admin quản lý mã giảm giá

actor Admin
participant "Next.js\n(Admin CMS)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

== Xem danh sách mã giảm giá ==
Admin -> FE : Mở trang quản lý coupon
FE -> BE : GET /api/v1/coupons
BE -> BE : Validate JWT + Authority\n(coupon.create / coupon.update\n/ coupon.delete)
BE -> DB : SELECT Coupon (tất cả)
BE --> FE : 200 {coupons[]}
FE --> Admin : Hiển thị danh sách\n(mã, loại, giá trị, thời hạn)

== Tạo mã giảm giá ==
Admin -> FE : Nhập thông tin coupon
FE -> BE : POST /api/v1/coupons\n{code, discountType, discountValue,\nminOrderValue, maxDiscount,\nmaxUses, startDate, endDate}
BE -> BE : Validate JWT + Authority\n(coupon.create)
BE -> DB : INSERT Coupon
BE --> FE : 201 {coupon}
FE --> Admin : Hiển thị coupon vừa tạo

== Cập nhật mã giảm giá ==
Admin -> FE : Sửa thông tin coupon
FE -> BE : PUT /api/v1/coupons/{id}\n{discountValue, endDate, ...}
BE -> BE : Validate JWT + Authority\n(coupon.update)
BE -> DB : UPDATE Coupon SET ...
BE --> FE : 200 {updatedCoupon}

== Xóa mã giảm giá ==
Admin -> FE : Nhấn "Xóa"
FE -> BE : DELETE /api/v1/coupons/{id}
BE -> BE : Validate JWT + Authority\n(coupon.delete)
BE -> DB : DELETE Coupon WHERE id = ?
BE --> FE : 200 {message:\n"Xóa thành công"}

== Validate coupon (public) ==
FE -> BE : GET /api/v1/coupons/validate\n?code=SUMMER2026&orderAmount=1000000
BE -> DB : SELECT Coupon WHERE code = ?
BE -> BE : Validate (còn hạn,\nchưa max_uses,\norderAmount >= minOrderValue)
BE --> FE : 200 {coupon + discountAmount}

@enduml
