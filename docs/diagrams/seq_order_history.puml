@startuml seq_order_history
title Hình 3.15 — Sequence Diagram — Xem lịch sử & Chi tiết đơn hàng

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

Customer -> FE : Mở trang "Đơn hàng của tôi"
FE -> BE : GET /api/v1/orders?\npage=1&size=10&status=ALL
BE -> BE : Validate JWT → user_id
BE -> DB : SELECT Orders WHERE user_id = ?\nORDER BY created_at DESC\nLIMIT 10 OFFSET 0
DB --> BE : Orders list + total count
BE --> FE : 200 {orders[], totalItems, totalPages}
FE --> Customer : Hiển thị danh sách đơn hàng\n(mã đơn, ngày, tổng tiền, trạng thái)

Customer -> FE : Nhấn vào đơn hàng cụ thể
FE -> BE : GET /api/v1/orders/{id}
BE -> BE : Validate JWT → kiểm tra\norder.user_id == current_user
BE -> DB : SELECT Orders JOIN Order_Detail\nJOIN Product JOIN Payment JOIN Shipping\nWHERE orders.id = ?
BE -> DB : SELECT Order_Status_History\nWHERE order_id = ?\nORDER BY created_at
DB --> BE : Full order details
BE --> FE : 200 {order, details[], payment,\nshipping, statusHistory[]}
FE --> Customer : Hiển thị chi tiết đơn\n(sản phẩm, thanh toán,\nvận chuyển, lịch sử trạng thái)

@enduml
