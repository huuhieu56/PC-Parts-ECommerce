@startuml seq_admin_users
title Hình 3.32 — Sequence Diagram — Admin quản lý người dùng

actor Admin
participant "Next.js\n(Admin CMS)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

== Xem danh sách tài khoản ==
Admin -> FE : Mở trang quản lý người dùng
FE -> BE : GET /api/v1/admin/accounts\n?page=0&size=50
BE -> BE : Validate JWT + Authority\n(system.admin)
BE -> DB : SELECT Account JOIN User_Profile\nJOIN Role\nORDER BY created_at DESC
BE --> FE : 200 {content[], page,\ntotalPages, totalElements}
FE --> Admin : Hiển thị danh sách\n(email, tên, phone, role,\ntrạng thái, lần đăng nhập cuối)

== Khóa / Mở khóa tài khoản ==
Admin -> FE : Nhấn "Khóa tài khoản"
FE -> BE : PUT /api/v1/admin/accounts/{id}/status\n{isActive: false}
BE -> BE : Validate JWT + Authority\n(system.admin)
BE -> DB : UPDATE Account\nSET is_active = false WHERE id = ?
BE --> FE : 200 {updatedAccount}
FE --> Admin : Cập nhật trạng thái

Admin -> FE : Nhấn "Mở khóa tài khoản"
FE -> BE : PUT /api/v1/admin/accounts/{id}/status\n{isActive: true}
BE -> DB : UPDATE Account\nSET is_active = true WHERE id = ?
BE --> FE : 200 {updatedAccount}

== Phân quyền người dùng ==
Admin -> FE : Thay đổi role của user
FE -> BE : PUT /api/v1/admin/accounts/{id}/role\n{roleName: "SALES"}
BE -> BE : Validate JWT + Authority\n(system.admin)
BE -> DB : SELECT Role WHERE name = ?
BE -> DB : UPDATE Account\nSET role_id = ? WHERE id = ?
BE --> FE : 200 {updatedAccount}
FE --> Admin : Cập nhật role hiển thị

@enduml
