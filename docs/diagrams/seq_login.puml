@startuml seq_login
title Hình 3.11 — Sequence Diagram — Đăng nhập & Merge giỏ hàng

actor Customer
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

Customer -> FE : Nhập email + password
FE -> BE : POST /api/v1/auth/login\n{email, password}

BE -> BE : Rate limit check\n(LoginRateLimiter)
alt Bị khóa do quá nhiều lần sai
    BE --> FE : 429 Too Many Requests
else Chưa bị khóa
    BE -> BE : AuthenticationManager\n.authenticate(email, password)
    alt Sai mật khẩu
        BE -> BE : Ghi nhận lần login fail
        BE --> FE : 401 Unauthorized
        FE --> Customer : Hiển thị lỗi
    else Tài khoản bị khóa
        BE --> FE : 403 Forbidden\n{Tài khoản đã bị khóa}
    else Đúng mật khẩu
        BE -> BE : Reset rate limiter
        BE -> DB : UPDATE Account\nSET last_login_at = NOW()
        BE -> DB : DELETE Token\nWHERE account_id = ?\n(xóa token cũ)
        BE -> BE : Sinh JWT Access Token
        BE -> DB : INSERT Token\n(type=ACCESS + REFRESH)
        BE --> FE : 200 {accessToken,\nrefreshToken, user}
        FE -> FE : Lưu token vào localStorage,\ncập nhật Zustand store
    end
end

note over FE, BE : Merge giỏ hàng\nlà bước riêng, gọi sau login

opt Frontend có sessionId (Guest cart)
    FE -> BE : POST /api/v1/cart/merge\nHeader: X-Session-Id
    BE -> BE : Validate JWT → accountId
    BE -> BE : Ghép cart Redis → DB
    BE --> FE : 200 {mergedCart}
end

FE --> Customer : Redirect về trang trước đó

@enduml
