@startuml seq_search_filter
title Hình 3.16 — Sequence Diagram — Duyệt, Tìm kiếm & Lọc sản phẩm

actor User
participant "Next.js\n(Frontend)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

User -> FE : Truy cập trang sản phẩm /\nnhập từ khóa / chọn bộ lọc
FE -> BE : GET /api/v1/products\n?page=0&size=20&sort=price_asc\n&keyword=xxx&categoryId=1&brandId=2\n&minPrice=X&maxPrice=Y\n&attributeValueIds=10,11&isSale=true

BE -> DB : SELECT Product JOIN Category\nJOIN Brand JOIN Inventory\nWHERE status='ACTIVE'\nAND (name ILIKE '%keyword%'\nOR sku ILIKE '%keyword%')\nAND category_id = ?\nAND brand_id = ?\nAND selling_price BETWEEN ? AND ?\nORDER BY ... LIMIT 20 OFFSET 0

opt Lọc theo thuộc tính (attributeValueIds)
    BE -> DB : AND product_id IN (\nSELECT product_id\nFROM Product_Attribute\nWHERE attribute_value_id\nIN (10, 11))
end

opt Lọc khuyến mãi (isSale=true)
    BE -> DB : AND selling_price < original_price
end

DB --> BE : Product list + total count
BE --> FE : 200 {content[], page,\ntotalPages, totalElements,\nhasNext, hasPrevious}
FE --> User : Hiển thị danh sách SP có pagination

opt Lấy bộ lọc động cho danh mục
    FE -> BE : GET /api/v1/products/filters\n?categoryId=1
    BE -> DB : SELECT Attribute + Attribute_Value\n+ Brand + price range\nWHERE category_id = ?
    BE --> FE : 200 {attributes[], brands[],\npriceRange{min, max}}
    FE --> User : Render sidebar bộ lọc động
end

@enduml
