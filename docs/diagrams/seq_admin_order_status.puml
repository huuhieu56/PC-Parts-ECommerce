@startuml seq_admin_order_status
title Hình 3.31 — Sequence Diagram — Admin cập nhật trạng thái đơn hàng

actor "Sales Staff" as Sales
participant "Next.js\n(Admin CMS)" as FE
participant "Spring Boot\n(Backend)" as BE
database "PostgreSQL" as DB

== Xem danh sách đơn hàng ==
Sales -> FE : Mở trang quản lý đơn hàng
FE -> BE : GET /api/v1/orders/admin\n?status=PENDING&page=0&size=20
BE -> BE : Validate JWT + Authority\n(order.view)
BE -> DB : SELECT Orders\nWHERE status = ?\nORDER BY created_at DESC
BE --> FE : 200 {content[], page,\ntotalPages, totalElements}
FE --> Sales : Hiển thị danh sách đơn

== Xem chi tiết đơn hàng ==
Sales -> FE : Nhấn vào đơn hàng
FE -> BE : GET /api/v1/orders/admin/{id}
BE -> BE : Validate JWT + Authority\n(order.view)
BE -> DB : SELECT Orders + Details\nWHERE id = ?
BE --> FE : 200 {order}

== Xác nhận đơn hàng ==
Sales -> FE : Nhấn "Xác nhận"\nđơn hàng PENDING
FE -> BE : PUT /api/v1/orders/{id}/status\n?status=CONFIRMED
BE -> BE : Validate JWT + Authority\n(order.update)
BE -> DB : SELECT Orders WHERE id = ?
BE -> BE : Validate transition\n(PENDING → CONFIRMED ✓)
BE -> DB : UPDATE Orders\nSET status = 'CONFIRMED'
BE -> DB : INSERT Order_Status_History
BE --> FE : 200 {updatedOrder}

== Chuyển trạng thái giao hàng ==
Sales -> FE : Chuyển SHIPPING
FE -> BE : PUT /api/v1/orders/{id}/status\n?status=SHIPPING
BE -> DB : UPDATE Orders\nSET status = 'SHIPPING'
BE -> DB : INSERT Order_Status_History
BE --> FE : 200 {updatedOrder}

== Hoàn thành đơn ==
Sales -> FE : Xác nhận đã giao thành công
FE -> BE : PUT /api/v1/orders/{id}/status\n?status=COMPLETED
BE -> DB : UPDATE Orders\nSET status = 'COMPLETED'
BE -> DB : INSERT Order_Status_History
BE --> FE : 200 {updatedOrder}

@enduml
