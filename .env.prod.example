# ============================================
# .env.prod — Production Seed Config
# Copy file này thành .env.prod và điền thông tin server
# ============================================

# [REQUIRED] Production API URL (public endpoint)
PROD_API_URL=https://pcparts.example.com/api/v1/auth

# [REQUIRED] SSH connection to production server
PROD_SSH_HOST=root@your-server-ip

# [OPTIONAL] SSH port (default: 22)
PROD_SSH_PORT=22

# [OPTIONAL] SSH authentication — chọn 1 trong 2:
# Cách 1: SSH key (ưu tiên hơn password)
# PROD_SSH_KEY=/path/to/your/private-key

# Cách 2: SSH password (cần cài sshpass: sudo apt install sshpass)
# PROD_SSH_PASS=your-ssh-password

# Nếu không set cả 2 → dùng SSH agent hoặc default key (~/.ssh/id_rsa)

# [OPTIONAL] Postgres container name on server (default: pc-parts-ecommerce-postgres-1)
PROD_POSTGRES_CONTAINER=pc-parts-ecommerce-postgres-1

# [OPTIONAL] Database credentials (default: pcparts/pcparts)
PROD_DB_USER=pcparts
PROD_DB_NAME=pcparts
