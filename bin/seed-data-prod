#!/usr/bin/env bash
# ============================================
# bin/seed-data-prod
# Seed test accounts on PRODUCTION server from local machine.
#
# Flow:
#   1. Register accounts via Production REST API (public endpoint)
#   2. SSH into server → docker exec postgres → UPDATE roles
#
# Postgres trên server KHÔNG expose port ra ngoài
# → Dùng SSH + docker exec để chạy SQL
#
# Usage:
#   # Set biến môi trường (hoặc tạo file .env.prod)
#   export PROD_API_URL=https://pcparts.example.com/api/v1/auth
#   export PROD_SSH_HOST=user@your-server-ip
#   export PROD_POSTGRES_CONTAINER=pc-parts-ecommerce-postgres-1
#   ./bin/seed-data-prod
#
#   # Hoặc inline:
#   PROD_API_URL=https://... PROD_SSH_HOST=root@1.2.3.4 ./bin/seed-data-prod
# ============================================

set -euo pipefail

# ── Load .env.prod nếu có ──────────────────────────────
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "${SCRIPT_DIR}")"
ENV_FILE="${PROJECT_DIR}/.env.prod"

if [[ -f "${ENV_FILE}" ]]; then
  echo "📄 Loading ${ENV_FILE}"
  set -a
  source "${ENV_FILE}"
  set +a
fi

# ── Config (tất cả qua biến môi trường) ────────────────
# Required
PROD_API_URL="${PROD_API_URL:?❌ PROD_API_URL chưa set. Ví dụ: https://pcparts.example.com/api/v1/auth}"
PROD_SSH_HOST="${PROD_SSH_HOST:?❌ PROD_SSH_HOST chưa set. Ví dụ: root@1.2.3.4}"

# Optional (có default)
PROD_SSH_PORT="${PROD_SSH_PORT:-22}"
PROD_SSH_KEY="${PROD_SSH_KEY:-}"    # Đường dẫn SSH key (ưu tiên hơn password)
PROD_SSH_PASS="${PROD_SSH_PASS:-}"  # SSH password (dùng sshpass, cần cài: apt install sshpass)
PROD_POSTGRES_CONTAINER="${PROD_POSTGRES_CONTAINER:-pc-parts-ecommerce-postgres-1}"
PROD_DB_USER="${PROD_DB_USER:-pcparts}"
PROD_DB_NAME="${PROD_DB_NAME:-pcparts}"
PROD_HEALTH_URL="${PROD_HEALTH_URL:-${PROD_API_URL%/auth}/actuator/health}"  # Derive from API URL
MAX_WAIT="${MAX_WAIT:-60}"

# ── Colors ──────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info()  { echo -e "${BLUE}ℹ️  $*${NC}"; }
log_ok()    { echo -e "${GREEN}✅ $*${NC}"; }
log_warn()  { echo -e "${YELLOW}⚠️  $*${NC}"; }
log_error() { echo -e "${RED}❌ $*${NC}"; }
log_step()  { echo -e "${CYAN}▶  $*${NC}"; }

# ── Run SSH command ────────────────────────────────────
# Trực tiếp chạy SSH thay vì build string (tránh lỗi word-splitting)
run_ssh() {
  local remote_cmd="$1"

  if [[ -n "${PROD_SSH_KEY}" ]]; then
    ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 \
      -p "${PROD_SSH_PORT}" -i "${PROD_SSH_KEY}" \
      "${PROD_SSH_HOST}" "${remote_cmd}"
  elif [[ -n "${PROD_SSH_PASS}" ]]; then
    if ! command -v sshpass &>/dev/null; then
      log_error "sshpass chưa cài. Chạy: sudo apt install sshpass"
      exit 1
    fi
    SSHPASS="${PROD_SSH_PASS}" sshpass -e \
      ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 \
      -p "${PROD_SSH_PORT}" \
      "${PROD_SSH_HOST}" "${remote_cmd}"
  else
    ssh -o StrictHostKeyChecking=no -o ConnectTimeout=10 \
      -p "${PROD_SSH_PORT}" \
      "${PROD_SSH_HOST}" "${remote_cmd}"
  fi
}

# ── 1. Check production API is reachable ───────────────
check_api() {
  log_info "Kiểm tra API production: ${PROD_API_URL}"

  local elapsed=0
  local check_url="${PROD_HEALTH_URL}"

  until curl -sf -k --max-time 5 "${check_url}" > /dev/null 2>&1; do
    if (( elapsed >= MAX_WAIT )); then
      log_warn "Health endpoint không phản hồi, thử API URL trực tiếp..."
      if curl -sf -k --max-time 5 "${PROD_API_URL}" > /dev/null 2>&1 || \
         curl -s -k --max-time 5 -o /dev/null -w "%{http_code}" "${PROD_API_URL}" 2>&1 | grep -q "4[0-9][0-9]"; then
        log_ok "API reachable (health endpoint không khả dụng nhưng API phản hồi)"
        return 0
      fi
      log_error "Production API không phản hồi sau ${MAX_WAIT}s"
      log_error "URL: ${check_url}"
      exit 1
    fi
    sleep 3
    elapsed=$((elapsed + 3))
    echo -ne "\r  ⏳ Đợi API... (${elapsed}s/${MAX_WAIT}s)"
  done
  echo ""
  log_ok "Production API ready!"
}

# ── 2. Check SSH connection ────────────────────────────
check_ssh() {
  log_info "Kiểm tra SSH: ${PROD_SSH_HOST}:${PROD_SSH_PORT}"

  if ! run_ssh "echo 'SSH OK'" > /dev/null 2>&1; then
    log_error "Không thể SSH vào ${PROD_SSH_HOST}:${PROD_SSH_PORT}"
    log_error "Kiểm tra: SSH key/password, firewall, hoặc PROD_SSH_HOST/PROD_SSH_PORT"
    exit 1
  fi
  log_ok "SSH connection OK"
}

# ── 3. Register account via Production REST API ───────
register() {
  local full_name="$1"
  local email="$2"
  local password="$3"
  local phone="$4"

  log_step "Đăng ký: ${email}"

  local http_code response
  response=$(curl -s -k -w "\n%{http_code}" -X POST "${PROD_API_URL}/register" \
    -H "Content-Type: application/json" \
    -d "{
      \"fullName\": \"${full_name}\",
      \"email\": \"${email}\",
      \"password\": \"${password}\",
      \"phone\": \"${phone}\"
    }" 2>&1)

  http_code=$(echo "${response}" | tail -1)
  local body
  body=$(echo "${response}" | sed '$d')

  case "${http_code}" in
    200|201)
      log_ok "${email} → Đăng ký thành công"
      ;;
    409|400)
      log_warn "${email} → Đã tồn tại hoặc trùng dữ liệu (HTTP ${http_code})"
      ;;
    *)
      log_error "${email} → Lỗi (HTTP ${http_code})"
      log_error "Response: ${body}"
      ;;
  esac
}

# ── 4. Run SQL on production via SSH + docker exec ─────
run_remote_sql() {
  local sql="$1"
  run_ssh "docker exec -i ${PROD_POSTGRES_CONTAINER} psql -U ${PROD_DB_USER} -d ${PROD_DB_NAME} -c \"${sql}\"" 2>/dev/null
}

# ── 5. Verify account exists ──────────────────────────
verify_account() {
  local email="$1"
  local expected_role="$2"

  local result
  result=$(run_ssh "docker exec -i ${PROD_POSTGRES_CONTAINER} psql -U ${PROD_DB_USER} -d ${PROD_DB_NAME} -t -c \"SELECT r.name FROM account a JOIN role r ON a.role_id = r.id WHERE a.email = '${email}';\"" 2>/dev/null | tr -d ' ')

  if [[ "${result}" == "${expected_role}" ]]; then
    log_ok "  ${email} → role = ${result} ✓"
  else
    log_warn "  ${email} → role = '${result}' (expected: ${expected_role})"
  fi
}

# ── Main ───────────────────────────────────────────────
main() {
  echo ""
  echo "╔══════════════════════════════════════════════════╗"
  echo "║   PC Parts E-Commerce — Seed Data (Production)  ║"
  echo "╚══════════════════════════════════════════════════╝"
  echo ""
  
  # Show config
  # Determine auth method
  local auth_method="SSH agent / default key"
  if [[ -n "${PROD_SSH_KEY}" ]]; then
    auth_method="Key: ${PROD_SSH_KEY}"
  elif [[ -n "${PROD_SSH_PASS}" ]]; then
    auth_method="Password (sshpass)"
  fi

  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "⚙️  Configuration:"
  echo "   API URL     : ${PROD_API_URL}"
  echo "   SSH Host    : ${PROD_SSH_HOST}:${PROD_SSH_PORT}"
  echo "   SSH Auth    : ${auth_method}"
  echo "   PG Container: ${PROD_POSTGRES_CONTAINER}"
  echo "   PG Database : ${PROD_DB_USER}@${PROD_DB_NAME}"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo ""

  # Step 1: Check connectivity
  check_api
  check_ssh

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "📝 Tạo tài khoản trên production"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # Step 2: Register accounts via public API
  register "System Admin"      "admin@pcparts.com"       "Admin@123"       "0901234567"
  register "Customer User"     "customer@pcparts.com"    "Customer@123"    "0901234568"
  register "Sales Staff"       "sales@pcparts.com"       "Sales@123"       "0901234569"
  register "Warehouse Staff"   "warehouse@pcparts.com"   "Warehouse@123"   "0901234570"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "🔑 Cập nhật roles (SSH → docker exec → psql)"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  # Step 3: Update roles via SSH + docker exec
  log_step "Gán role ADMIN cho admin@pcparts.com"
  run_remote_sql "UPDATE account SET role_id = (SELECT id FROM role WHERE name = 'ADMIN') WHERE email = 'admin@pcparts.com';"

  log_step "Gán role SALES cho sales@pcparts.com"
  run_remote_sql "UPDATE account SET role_id = (SELECT id FROM role WHERE name = 'SALES') WHERE email = 'sales@pcparts.com';"

  log_step "Gán role WAREHOUSE cho warehouse@pcparts.com"
  run_remote_sql "UPDATE account SET role_id = (SELECT id FROM role WHERE name = 'WAREHOUSE') WHERE email = 'warehouse@pcparts.com';"

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "🏠 Thêm địa chỉ mẫu cho customer"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  log_step "Thêm địa chỉ cho customer@pcparts.com"
  run_remote_sql "
    INSERT INTO address (user_id, label, receiver_name, receiver_phone, province, district, ward, street, is_default)
    SELECT up.id, 'Nhà', 'Customer User', '0901234568', 'TP. Hồ Chí Minh', 'Quận 1', 'Phường Bến Nghé', '123 Nguyễn Huệ', true
    FROM user_profile up
    JOIN account a ON up.account_id = a.id
    WHERE a.email = 'customer@pcparts.com'
    AND NOT EXISTS (
      SELECT 1 FROM address addr WHERE addr.user_id = up.id
    );
  "

  echo ""
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
  echo "🔍 Xác nhận kết quả"
  echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

  verify_account "admin@pcparts.com"     "ADMIN"
  verify_account "sales@pcparts.com"     "SALES"
  verify_account "warehouse@pcparts.com" "WAREHOUSE"
  verify_account "customer@pcparts.com"  "CUSTOMER"

  echo ""
  echo "╔══════════════════════════════════════════════════╗"
  echo "║        ✅ Production seed hoàn tất!             ║"
  echo "╚══════════════════════════════════════════════════╝"
  echo ""
  echo "┌──────────────┬───────────────────────────┬───────────────┐"
  echo "│ Role         │ Email                     │ Password      │"
  echo "├──────────────┼───────────────────────────┼───────────────┤"
  echo "│ ADMIN        │ admin@pcparts.com         │ Admin@123     │"
  echo "│ SALES        │ sales@pcparts.com         │ Sales@123     │"
  echo "│ WAREHOUSE    │ warehouse@pcparts.com     │ Warehouse@123 │"
  echo "│ CUSTOMER     │ customer@pcparts.com      │ Customer@123  │"
  echo "└──────────────┴───────────────────────────┴───────────────┘"
  echo ""
}

main "$@"
