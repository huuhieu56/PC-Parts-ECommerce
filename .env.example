# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/pc_shop_database
SPRING_DATASOURCE_USERNAME=your_username
SPRING_DATASOURCE_PASSWORD=your_password

# Server
SERVER_PORT=8080

# CORS (comma-separated origins or * for all)
APP_CORS_ALLOWED_ORIGINS=*

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api/v1
FRONTEND_PORT=8081

# AI Advisor (optional - for PC build advisor feature)
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_MODEL=gemini-2.5-flash

# JWT (optional - defaults are set in application.yml)
# APP_JWT_SECRET=your_jwt_secret_key
# APP_JWT_EXPIRATION=2592000000
