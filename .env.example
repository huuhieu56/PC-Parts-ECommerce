# ===========================
# PC Parts E-Commerce — Env
# ===========================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.

# --- PostgreSQL ---
POSTGRES_DB=pcparts
POSTGRES_USER=pcparts
POSTGRES_PASSWORD=your_database_password_here

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/pcparts
SPRING_DATASOURCE_USERNAME=pcparts
SPRING_DATASOURCE_PASSWORD=your_database_password_here

# --- Redis ---
REDIS_PASSWORD=your_redis_password_here
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=your_redis_password_here

# --- JWT (generate a 256-bit key: openssl rand -base64 32) ---
JWT_SECRET=your_base64_encoded_256bit_secret_here
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=2592000000

# --- MinIO ---
MINIO_ENDPOINT=http://minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=your_minio_password_here
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=your_minio_secret_here
MINIO_BUCKET=pcparts

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost/api/v1
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# --- Email (optional) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
