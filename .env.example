# ============================================
# PC Parts E-Commerce — Environment Variables
# ============================================
# Development environment — safe to use as-is
# For production: generate new secrets!

# --- PostgreSQL ---
POSTGRES_DB=pcparts
POSTGRES_USER=pcparts
POSTGRES_PASSWORD=pcparts_secret_2026

# --- Redis ---
REDIS_PASSWORD=redis_secret_2026

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret_2026
MINIO_BUCKET=pcparts

# --- Backend (Spring Boot) ---
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/pcparts
SPRING_DATASOURCE_USERNAME=pcparts
SPRING_DATASOURCE_PASSWORD=pcparts_secret_2026
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=redis_secret_2026

# JWT Secret (valid base64, 256-bit key)
JWT_SECRET=Q09OhlkoVLpsdYr95wOTjqHsB67JvNv9ncEkPsHta3g=
JWT_ACCESS_EXPIRATION=900000
JWT_REFRESH_EXPIRATION=2592000000

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_secret_2026

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost/api/v1
NEXT_PUBLIC_MINIO_URL=http://localhost:9000

# --- Email (SMTP — optional, disabled in dev) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

# --- Cerebras AI (LLM for Build PC compatibility check) ---
CEREBRAS_API_KEY=your_cerebras_api_key_here
CEREBRAS_BASE_URL=https://api.cerebras.ai/v1
CEREBRAS_MODEL=llama3.1-8b
CEREBRAS_TIMEOUT=30000
